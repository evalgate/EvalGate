{
	"$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/.next",
			"!**/dist",
			"!**/.evalai",
			"!**/node_modules",
			"!**/drizzle/meta",
			"!**/coverage"
		]
	},
	"css": {
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui/input-group.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useKeyWithClickEvents": "off",
						"noStaticElementInteractions": "off"
					}
				}
			}
		},
		{
			"includes": ["src/components/ui/workflow-dag.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"noStaticElementInteractions": "off"
					}
				}
			}
		},
		{
			"includes": ["src/components/workflow-dag.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off"
					}
				}
			}
		},
		{
			"includes": ["src/lib/auth.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": ["tests/**/*.test.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["src/components/ui/keyboard-shortcuts-help.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["src/remotion/**/*"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					},
					"a11y": {
						"noSvgWithoutTitle": "off"
					}
				}
			}
		},
		{
			"includes": ["src/visual-edits/**/*"],
			"linter": {
				"rules": {
					"suspicious": {
						"noAssignInExpressions": "off",
						"noArrayIndexKey": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off"
					},
					"a11y": {
						"noStaticElementInteractions": "off"
					}
				}
			}
		}
	]
}
